{
  "name": "aigc-assistant",
  "version": "1.0.0",
  "description": "AIGC 辅助工具",
  "main": "index.js",
  "scripts": {
    "start:backend": "node backend/server.js",
    "start:frontend": "cd frontend && npm run dev",
    "start:image-service": "cd image-service && uv run uvicorn main:app --host 0.0.0.0 --port 8001 --reload",
    "dev": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "dev:full": "concurrently \"npm run start:backend\" \"npm run start:frontend\" \"npm run start:image-service\"",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "express": "^4.18.3",
    "multer": "^1.4.5-lts.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sequelize": "^6.37.1",
    "sqlite3": "^5.1.7",
    "vite": "^5.2.0"
  },
  "devDependencies": {
    "concurrently": "^7.6.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1"
  }
}
