# Database Configuration
# Supported types: sqlite, postgres
DB_TYPE=sqlite

# SQLite Configuration (used when DB_TYPE=sqlite)
DB_STORAGE=./database.db

# PostgreSQL Configuration (used when DB_TYPE=postgres)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aigc_assistant
DB_USER=postgres
DB_PASSWORD=postgres

# PostgreSQL SSL (set to 'true' for production with SSL)
DB_SSL=false

# Database Logging (set to 'true' to enable SQL query logging)
DB_LOGGING=false

# Connection Pool Settings (PostgreSQL only)
DB_POOL_MAX=5
DB_POOL_MIN=0
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000
